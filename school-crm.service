[Unit]
Description=School Support CRM Application
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/school-crm
Environment="PATH=/opt/school-crm/venv/bin"
ExecStart=/opt/school-crm/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
